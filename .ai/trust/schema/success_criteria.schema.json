{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-cockpit://trust/success-criteria.schema.json",
  "title": "Success Criteria Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workItemId", "criteria"],
  "properties": {
    "schemaVersion": {"const": 1},
    "workItemId": {"type": "string", "minLength": 1},
    "criteria": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "statement": {"type": "string", "minLength": 1},
          "evidenceHints": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  },
  "examples": [
    {
      "schemaVersion": 1,
      "workItemId": "trust_schema_foundation",
      "criteria": [{"id": "SC-001", "statement": "Malformed Trust Layer records are rejected before a guard consumes them.", "evidenceHints": ["make check-trust-schemas"]}]
    }
  ]
}
