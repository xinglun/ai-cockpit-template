  "guidelines": [],
  "intent": {
    "problem": "The installer's adoption path computes baseCommit with Git commands that can inherit GIT_DIR or GIT_WORK_TREE from the caller, so a target repository can accidentally record the HEAD of an unrelated repository as its trust root.",
    "constraints": [
      "Keep the public adoption flow and its output shape unchanged except for the corrected trust root.",
      "Do not weaken the existing clean-worktree and no-active-work-item preflight checks.",
      "Keep the fix local to the installer and its regression tests."
    ],
    "rationale": "A small environment-isolation fix in the installer is the lowest-risk way to make adoption evidence trustworthy without changing the broader governance model."
  },
